NODE_ENV=production
PORT=3000

# PostgreSQL connection string from Supabase, Railway, Render, Neon, or your VPS database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Set true for hosted PostgreSQL providers that require SSL.
DATABASE_SSL=true

# Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret

# Optional: comma-separated owner emails that should see the SaaS Admin section.
ADMIN_EMAILS=owner@example.com

# Optional. Example: https://yourdomain.com
CORS_ORIGIN=
